# ═══════════════════════════════════════════════════
# EZAI — Variables de Entorno
# Copia este archivo como .env y rellena cada valor
# NUNCA subas el archivo .env a GitHub
# ═══════════════════════════════════════════════════

# ───────────────────────────────────────────────────
# SERVIDOR
# ───────────────────────────────────────────────────

# Puerto donde corre el servidor Node.js
PORT=3000

# URL pública del servidor (usada para webhooks de Telnyx)
# En desarrollo usa ngrok: https://xxxx.ngrok.io
# En producción: https://api.ezai.com
SERVER_URL=https://tu-servidor.com

# Entorno: development | production
NODE_ENV=development

# ───────────────────────────────────────────────────
# TELNYX — Telefonía
# Obtén estas claves en: https://portal.telnyx.com
# ───────────────────────────────────────────────────

# API Key de Telnyx (empieza con "KEY")
TELNYX_API_KEY=KEY_xxxxxxxxxxxxxxxxxxxxxxxx

# Public Key de Telnyx — para verificar que los webhooks
# son reales y vienen de Telnyx (no de un atacante)
TELNYX_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ID de la aplicación de Call Control en Telnyx
# Se crea en: Portal Telnyx > Voice > Call Control
TELNYX_APP_ID=xxxxxxxxxxxxxxxxxxxxxxxx

# ───────────────────────────────────────────────────
# DEEPGRAM — Speech-to-Text
# Obtén tu API key en: https://console.deepgram.com
# ───────────────────────────────────────────────────

# API Key de Deepgram
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# Modelo a usar (recomendado: nova-3 para español)
DEEPGRAM_MODEL=nova-3

# Idioma base (el agente también detecta inglés automáticamente)
DEEPGRAM_LANGUAGE=es

# ───────────────────────────────────────────────────
# ANTHROPIC (CLAUDE) — Cerebro del Agente
# Obtén tu API key en: https://console.anthropic.com
# ───────────────────────────────────────────────────

# API Key de Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Modelo de Claude a usar
CLAUDE_MODEL=claude-sonnet-4-6

# Temperatura del modelo (0 = determinístico, 1 = creativo)
# Para el agente médico usamos 0.3 — respuestas consistentes pero naturales
CLAUDE_TEMPERATURE=0.3

# Máximo de tokens en la respuesta de Claude
CLAUDE_MAX_TOKENS=1024

# ───────────────────────────────────────────────────
# CARTESIA — Text-to-Speech
# Obtén tu API key en: https://www.cartesia.ai
# ───────────────────────────────────────────────────

# API Key de Cartesia
CARTESIA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ID de la voz a usar (español mexicano, femenino, cálido)
# Busca voces en: https://play.cartesia.ai
CARTESIA_VOICE_ID=xxxxxxxxxxxxxxxxxxxxxxxx

# Modelo de Cartesia
CARTESIA_MODEL=sonic-3

# ───────────────────────────────────────────────────
# GOOGLE CALENDAR — Agendado de Citas
# Instrucciones: https://developers.google.com/calendar
# Crea un Service Account en Google Cloud Console
# ───────────────────────────────────────────────────

# Email del Service Account de Google
# Formato: nombre@proyecto.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=ezai@mi-proyecto.iam.gserviceaccount.com

# JSON completo del Service Account en Base64
# Para convertir: cat key.json | base64
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=xxxxxxxxxxxxxxxxxxxxxxxx

# ID del calendario del médico
# Se encuentra en: Google Calendar > Configuración del calendario > ID del calendario
GOOGLE_CALENDAR_ID=doctor@gmail.com

# ───────────────────────────────────────────────────
# SUPABASE — Base de Datos
# Obtén estas claves en: https://app.supabase.com
# Proyecto > Settings > API
# ───────────────────────────────────────────────────

# URL del proyecto de Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clave pública (anon key) — uso limitado, segura para el cliente
SUPABASE_ANON_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# Clave privada (service_role) — acceso total, NUNCA exponerla al cliente
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ───────────────────────────────────────────────────
# CLOUDFLARE R2 — Grabaciones de Audio
# Obtén estas claves en: https://dash.cloudflare.com
# R2 > Manage R2 API Tokens
# ───────────────────────────────────────────────────

# ID de tu cuenta de Cloudflare
CLOUDFLARE_R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxx

# Access Key ID del token de R2
CLOUDFLARE_R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxx

# Secret Access Key del token de R2
CLOUDFLARE_R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# Nombre del bucket de R2 donde se guardan las grabaciones
CLOUDFLARE_R2_BUCKET_NAME=ezai-recordings

# URL pública del bucket (si habilitaste acceso público en R2)
# Si no, déjalo vacío y se usarán URLs firmadas (más seguro)
CLOUDFLARE_R2_PUBLIC_URL=

# ───────────────────────────────────────────────────
# CONFIGURACIÓN DEL AGENTE TEST 0.1
# ───────────────────────────────────────────────────

# ID del negocio por defecto (para desarrollo)
# En producción, este valor se determina por el número de teléfono
DEFAULT_BUSINESS_ID=test-consultorio-01

# Número de teléfono del consultorio (el que registraste en Telnyx)
# Formato E.164: +521XXXXXXXXXX
CONSULTORIO_PHONE_NUMBER=+521XXXXXXXXXX

# Número al que se transfieren las emergencias o llamadas complejas
# Puede ser el número directo del médico
TRANSFER_PHONE_NUMBER=+521XXXXXXXXXX

# ───────────────────────────────────────────────────
# LOGS Y MONITOREO
# ───────────────────────────────────────────────────

# Nivel de logs: error | warn | info | debug
# En producción usar "info", en desarrollo "debug"
LOG_LEVEL=debug

# Directorio donde se guardan los logs (relativo a /server)
LOG_DIR=./logs
